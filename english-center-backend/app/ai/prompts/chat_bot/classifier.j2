Schema JSON bắt buộc:
{
  "user_info": {
    "name": string | null,
    "email": string | null,
    "phone": string | null
  },
  "course_info": {
    "key_name": string | null,
    "code": string | null
  },
  "class_by_course": {
    "course_id": string | null
  },
  "course_filter": {
    "level": "beginner" | "elementary" | "intermediate" | "advanced" | null,
    "goal": string | null,
    "age_group": string | null,
    "schedule": string | null
  },
  "intents": string[],
  "allowed_actions": [
    {
      "type": "course" | "class" | "lead" | "user_info",
      "name": "list_current_courses" | "search_course" | "filter_courses" | "get_course_price" | "get_course_schedule" | "get_classes_by_course" | "collect_user_info" | "save_lead",
      "priority": number
    }
  ],
  "rejected_intents": [
    {
      "intent": string,
      "reason": string
    }
  ],
  "primary_intent": string | null,
  "confidence": number
}
