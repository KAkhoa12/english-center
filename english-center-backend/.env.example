# App
APP_NAME=english-center-api
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
API_V1_PREFIX=/api/v1

# Database
POSTGRES_DB=english_center_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/english_center_db

# JWT
JWT_SECRET_KEY=change_me
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_PUBLIC_ENDPOINT=localhost:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_SECURE=false

MINIO_BUCKET_AVATARS=avatars
MINIO_BUCKET_MATERIALS=materials
MINIO_BUCKET_SUBMISSIONS=submissions
MINIO_BUCKET_VIDEOS=videos
MINIO_BUCKET_EXPORTS=exports

MINIO_PRESIGNED_EXPIRE_SECONDS=3600

# LLM
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LOW_LLM_MODEL=qwen2.5:3b
OLLAMA_HIGH_LLM_MODEL=llama3.1:70b
OLLAMA_RERANK_MODEL=bge-reranker-v2-m3
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_TIMEOUT_SECONDS=120
OLLAMA_TEMPERATURE=0.2
OLLAMA_API_KEY=your_api_key_here
# LangGraph
LANGGRAPH_CHECKPOINTER=memory
LANGGRAPH_THREAD_ID_PREFIX=ec
LANGGRAPH_RECURSION_LIMIT=50

# Qdrant
QDRANT_URL=
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=
QDRANT_COLLECTION_PREFIX=english_center
